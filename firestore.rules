rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Cada usuário só lê e escreve os próprios dados
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
